{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@novabase/rules/*": ["services/rules/src/*"],
      "@novabase/docdb/*": ["services/docdb/src/*"],
      "@novabase/auth/*": ["services/auth/src/*"],
      "@novabase/sdk/*": ["sdk/js/src/*"]
    }
  }
}
